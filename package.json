{
  "name": "tip",
  "version": "1.0.0",
  "private": true,
  "description": "The Token Improvement Plan - infrastructure for increasing token usage in your workflows.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "yethdev",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "tip": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tip.schema.json",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve": "node scripts/serve.mjs",
    "ledger:dev": "wrangler dev --config worker/wrangler.toml",
    "ledger:deploy": "wrangler deploy --config worker/wrangler.toml",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20241218.0",
    "@eslint/js": "9.17.0",
    "@types/node": "22.10.2",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.8",
    "wrangler": "3.99.0"
  }
}
